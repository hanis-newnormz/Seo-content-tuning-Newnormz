# Supabase project settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, never exposed to the browser.
# Used to verify client share tokens and serve the public client view.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of this app, used to build client share links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
